# Copy to .env and fill in. NEVER commit .env (§1: no secrets in code).

# --- xAI Grok (highlight selection + metadata) ---
# https://console.x.ai  ->  API Keys
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- YouTube Data API v3 (OAuth 2.0 installed-app flow) ---
# Path to the OAuth *client secret* JSON downloaded from Google Cloud Console
# (APIs & Services -> Credentials -> OAuth client ID -> Desktop app).
YOUTUBE_CLIENT_SECRETS=client_secret.json

# Where the user-authorized token gets cached after `clipper auth`.
YOUTUBE_TOKEN_PATH=youtube_token.json
